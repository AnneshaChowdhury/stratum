# For Docker (docker compose up): use db:5432 as the host
# For local dev (outside Docker): use localhost:5432
DATABASE_URL=postgresql+asyncpg://stratum:stratum@localhost:5432/stratum
GROQ_API_KEY=your_free_key_from_console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=stratum-agent
KAFKA_BATCH_SIZE=50
KAFKA_BATCH_TIMEOUT_MS=5000
